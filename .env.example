# Copy to .env.local and fill in values.

# --- Celo / MiniPay ---
# WalletConnect project ID (get from cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- cUSD Wager ---
# Address that receives entry fees and pays out winnings
NEXT_PUBLIC_TREASURY_ADDRESS=

# Private key of the treasury wallet (server-side only — NEVER prefix with NEXT_PUBLIC_)
# Used by /api/payout to send 0.18 cUSD to match winners
TREASURY_PRIVATE_KEY=
